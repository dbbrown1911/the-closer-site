# ─────────────────────────────────────────────────────────────
# ValleyMLS data feed — platform: BRIDGE (Bridge Data Output / Zillow Group)
# Set these in Netlify: Site settings → Environment variables.
# NEVER commit real values. This file is just a template.
# ─────────────────────────────────────────────────────────────

# Bridge uses a STATIC SERVER TOKEN (no OAuth handshake).
# You only need the two variables below.

# 1) Your Bridge OData endpoint. Format:
#    https://api.bridgedataoutput.com/api/v2/OData/<dataset-name>
#    <dataset-name> is ValleyMLS's dataset slug, shown on your Bridge
#    app's credentials/endpoints page. No trailing slash, no /Property.
RESO_BASE_URL=

# 2) Your Bridge "Server Token" — a long string. Treat it like a password.
RESO_TOKEN=

# ── Leave the OAuth vars BELOW blank. Bridge does not use them. ──
# (They exist only so this scaffold also works on OAuth platforms
#  like Trestle/CoreLogic if you ever switch.)
RESO_TOKEN_URL=
RESO_CLIENT_ID=
RESO_CLIENT_SECRET=
RESO_SCOPE=

# Optional: scope the public search to your market.
DEFAULT_CITIES=Huntsville,Madison,Athens,Harvest,Meridianville,Owens Cross Roads
